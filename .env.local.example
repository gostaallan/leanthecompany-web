# Copy to .env.local and fill in the real values.
# .env.local is gitignored.

# --- Formspree waitlist form endpoints -----------------------------------
# Create separate forms on https://formspree.io for clean reporting:
#   1. "LeanTheCompany — Waitlist"      (newsletter + early access)
#   2. "LeanTheCompany — Chaos Score"   (lead magnet download)
# Paste the full endpoint URLs here.
NEXT_PUBLIC_FORMSPREE_WAITLIST=https://formspree.io/f/xxxxxxxx
NEXT_PUBLIC_FORMSPREE_CHAOS_SCORE=https://formspree.io/f/yyyyyyyy

# --- Site config ---------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://leanthecompany.com

# --- Plausible analytics (optional) --------------------------------------
# Leave empty to disable. If set, add <script> in layout.tsx.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=leanthecompany.com
